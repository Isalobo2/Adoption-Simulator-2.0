<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.petadoption.controller.MainController"
            stylesheets="@../css/styles.css">

    <!-- ── Top toolbar ── -->
    <top>
        <VBox styleClass="toolbar">
            <Label text="Paw &amp; Home Adoption Agency" styleClass="toolbar-title"/>
            <HBox spacing="8" styleClass="filter-bar">
                <Button fx:id="btnAll"  text="All pets" onAction="#showAll"  styleClass="filter-btn"/>
                <Button fx:id="btnDogs" text="Dogs"     onAction="#showDogs" styleClass="filter-btn"/>
                <Button fx:id="btnCats" text="Cats"     onAction="#showCats" styleClass="filter-btn"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── Centre: list + detail panel ── -->
    <center>
        <SplitPane dividerPositions="0.55" styleClass="main-split">

            <!-- Left: scrollable pet list -->
            <ScrollPane fitToWidth="true" styleClass="list-scroll">
                <VBox fx:id="petListContainer" spacing="8" styleClass="pet-list">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                </VBox>
            </ScrollPane>

            <!-- Right: detail panel -->
            <VBox fx:id="detailPanel" spacing="0" styleClass="detail-panel">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label fx:id="detailName"    styleClass="detail-name"  text="Select a pet"/>
                <Label fx:id="detailSubtitle" styleClass="detail-sub"  text=""/>

                <Separator styleClass="detail-sep"/>

                <GridPane fx:id="detailGrid" styleClass="detail-grid" hgap="8" vgap="0">
                    <Label text="Age"    GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="detail-label"/>
                    <Label fx:id="detailAge"    GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="detail-val"/>
                    <Label text="Weight" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="detail-label"/>
                    <Label fx:id="detailWeight" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="detail-val"/>
                    <Label text="Breed"  GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="detail-label"/>
                    <Label fx:id="detailBreed"  GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="detail-val"/>
                    <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="detail-label"/>
                    <Label fx:id="detailStatus" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="detail-val"/>
                </GridPane>

                <Separator styleClass="detail-sep"/>

                <Label text="About" styleClass="desc-heading"/>
                <TextArea fx:id="detailDesc" styleClass="desc-area" wrapText="true"
                          editable="false" prefHeight="100"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button fx:id="adoptBtn" text="Adopt" styleClass="adopt-btn"
                        onAction="#handleAdopt" maxWidth="Infinity" disable="true"/>
            </VBox>
        </SplitPane>
    </center>

    <!-- ── Bottom status bar ── -->
    <bottom>
        <HBox styleClass="status-bar">
            <Label fx:id="statusLabel" text="Loading..."/>
        </HBox>
    </bottom>

</BorderPane>
